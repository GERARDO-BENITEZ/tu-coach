# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/tu_coach_dev"

# JWT — genera con: openssl rand -base64 64
JWT_SECRET="super-secret-key-change-in-production"
JWT_REFRESH_SECRET="another-secret-for-refresh-tokens"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Garmin OAuth
GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""

# Whoop API
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
WHOOP_REDIRECT_URI="http://localhost:3001/integrations/whoop/callback"

# Notificaciones push (OneSignal)
ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL="no-reply@tucoach.app"
