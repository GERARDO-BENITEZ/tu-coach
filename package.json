{
  "name": "tu-coach-server",
  "version": "1.0.0",
  "description": "Tu Coach — servidor local (Express + JSON store, sin compilación nativa)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind-output.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind-output.css --watch",
    "postinstall": "npm run build:css"
  },
  "dependencies": {
    "autoprefixer": "^10.5.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "garmin-connect": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "uuid": "^9.0.1"
  }
}
