# ── Tu Coach — Variables de entorno ──────────────────────────────────────────
# Copia este archivo a .env y rellena tus credenciales reales.
# NUNCA subas .env a GitHub.

# ── Garmin Connect ────────────────────────────────────────────────────────────
GARMIN_EMAIL=tu@email.com
GARMIN_PASSWORD=tu_contraseña_garmin

# ── Whoop Developer API ───────────────────────────────────────────────────────
# Regístrate en: https://developer.whoop.com/ → My Apps → Create App
# Callback URL a registrar: http://localhost:3001/api/auth/whoop/callback
WHOOP_CLIENT_ID=tu_whoop_client_id
WHOOP_CLIENT_SECRET=tu_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:3001/api/auth/whoop/callback
